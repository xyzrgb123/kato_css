+box('.item')
    color var(--c5)
    list-style-type none
    background-color var(--c1)
    padding 0.5rem 1rem
    border-width inherit
    border-color inherit
    border-color var(--c3)
    border-width var(--border-width)
    border-style solid
    border-radius var(--rem1)

+box('.item.clickable')
    &[disabled]
        color var(--c3)
    &:not([disabled])
        cursor pointer
        &.active
        &:hover
            background-color var(--c2)
            color var(--c7)
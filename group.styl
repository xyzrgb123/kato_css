.group
    display inline-flex
    &>*
        margin 0
    &:not(.vertical)>*
        &:not(:last-child)
            border-right-width calc(var(--border-width) / 2)
            border-top-right-radius 0
            border-bottom-right-radius 0
        &:not(:first-child)
            border-left-width calc(var(--border-width) / 2)
            border-top-left-radius 0
            border-bottom-left-radius 0
    &.vertical
        flex-direction column
        align-items flex-start
        &>*
            flex 1 1 auto
            width 100%
            &:not(:last-child)
                border-bottom-width calc(var(--border-width) / 2)
                border-bottom-right-radius 0
                border-bottom-left-radius 0
            &:not(:first-child)
                border-top-width calc(var(--border-width) / 2)
                border-top-right-radius 0
                border-top-left-radius 0

.btn-group
    @extend .group
    &>*
        @extend .btn

.list-group
    color var(--c5)
    list-style-type none
    @extend .group
    &>*
        background-color var(--c1)
        padding 0.5rem 1rem
        border-width inherit
        border-color inherit
        border-color var(--c3)
        border-width var(--border-width)
        border-style solid
        border-radius var(--rem1)
        &[disabled]
            color var(--c3)
.list-group>*.active
.list-group.action>*:not([disabled]):hover
    background-color var(--c2)
    color var(--c7)
.list-group.action>*:not([disabled])
    cursor pointer
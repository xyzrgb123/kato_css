html
    background-color rgb(178, 178, 201)

body
    padding 2rem

*, ::after, ::before
    font-family system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", "Noto Sans", "Liberation Sans", Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji"
    box-sizing border-box
    --rem1 0.375rem
    --border-width 1px
    position relative
    font-weight 400
    transition 200ms
    margin 0
    padding 0
    border-width var(--border-width)

[disabled]
    cursor auto !important
    background-color var(--background-color-disabled, var(--background-color)) !important
    border-color var(--border-color-disabled, var(--border-color)) !important
    color var(--color-disabled, var(--color)) !important

ol
    counter-reset n
    &>*
        counter-increment n
        &:before
            content counter(n) '.'
            margin-right 0.5em
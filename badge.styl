.badge
    display inline-block
    font-size 0.75em
    font-weight 700
    padding 0.35em 0.65em
    border-radius var(--rem1)
    text-align center
    line-height 1
    white-space nowrap
    vertical-align baseline
    color var(--c1)
    background-color var(--c4)
    &.corner
        position absolute
        right 0
        top 0
        border-radius 50rem
        transform translate(50%, -50%)